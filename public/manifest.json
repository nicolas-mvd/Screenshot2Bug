{
  "manifest_version": 3,
  "name": "Screenshot2Bug",
  "description": "Capture screenshots or videos with browser context and generate AI bug reports.",
  "version": "0.1.0",
  "action": {
    "default_title": "Screenshot2Bug",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "downloads",
    "tabCapture",
    "offscreen",
    "unlimitedStorage"
  ],
  "host_permissions": ["<all_urls>", "https://api.openai.com/*"],
  "commands": {
    "capture-screenshot": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Start a new screenshot bug report"
    },
    "attach-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Attach a screenshot to the active bug report"
    },
    "capture-video": {
      "suggested_key": {
        "default": "Alt+Shift+V",
        "mac": "Alt+Shift+V"
      },
      "description": "Start a new video bug report"
    },
    "attach-video": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "MacCtrl+Shift+V"
      },
      "description": "Attach a video to the active bug report"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
